# ── Frontend Environment Variables ────────────────────────────────────
# All variables with the VITE_ prefix are exposed to the browser.
# Do NOT put secrets (API keys, tokens, passwords) here.
#
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env

# Required: Backend API base URL (no trailing slash).
#   Development: http://localhost:8080
#   Production:  https://api.grainlify.com
VITE_API_BASE_URL=http://localhost:8080

# Optional: Frontend base URL (defaults to window.location.origin).
# Only set this if the frontend origin differs from the browser URL
# (e.g., when running behind a reverse proxy).
#   Development: http://localhost:5173
#   Production:  https://grainlify.com
# VITE_FRONTEND_BASE_URL=http://localhost:5173